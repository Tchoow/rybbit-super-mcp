# Rybbit Super MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: URL of your Rybbit instance (no trailing slash)
RYBBIT_URL=https://your-rybbit-instance.com

# Recommended: API Key (used first for all requests — stateless, fast)
RYBBIT_API_KEY=your-api-key-here

# Recommended: Email/Password (automatic fallback for CRUD on older Rybbit versions)
# When API key returns 403, the MCP retries with session auth transparently.
RYBBIT_EMAIL=your-email@example.com
RYBBIT_PASSWORD=your-password
