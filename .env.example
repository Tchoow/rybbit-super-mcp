# Rybbit Super MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: URL of your Rybbit instance (no trailing slash)
RYBBIT_URL=https://your-rybbit-instance.com

# Recommended: Email/Password authentication (full access to all 48 tools)
# Required for funnel/goal CRUD tools — API key auth returns 403 on these
# endpoints due to a Rybbit server limitation.
RYBBIT_EMAIL=your-email@example.com
RYBBIT_PASSWORD=your-password

# Optional: API Key authentication (read-only + site config, 39/48 tools)
# If both email/password AND API key are provided, email/password is used.
# RYBBIT_API_KEY=your-api-key-here
